{
  "manifest_version": 3,
  "name": "Kurripu Extension",
  "version": "1.0",
  "description": "Quickly create aesthetic sticky notes.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Create a Note"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://*/*"
  ]
}
